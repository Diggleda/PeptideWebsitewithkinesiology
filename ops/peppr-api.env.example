# TrufusionLabs production runtime environment template
# Copy the values manually into /etc/peppr-api.env on the VPS.
# Do not rename this file to .env in the repo, and do not commit live secrets.

NODE_ENV=production
PORT=3001
DATA_DIR=/opt/peppr/backend/server-data

# Required security settings
JWT_SECRET=replace-with-a-long-random-secret
DATA_ENCRYPTION_KEY=replace-with-a-base64-32-byte-secret
DATA_ENCRYPTION_BLIND_INDEX_KEY=replace-with-a-base64-32-byte-secret
DATA_ENCRYPTION_KEY_VERSION=prod-v1
MYSQL_SSL=true
FRONTEND_BASE_URL=https://www.trufusionlabs.com
CORS_ALLOW_ORIGINS=https://www.trufusionlabs.com,https://trufusionlabs.com,https://shop.trufusionlabs.com
PASSKEY_RP_ID=trufusionlabs.com
PASSKEY_ALLOWED_ORIGINS=https://www.trufusionlabs.com

# Typical runtime settings
TRUFUSION_WEB_BACKGROUND_JOBS_MODE=external
MYSQL_ENABLED=true
MYSQL_HOST=replace-me
MYSQL_PORT=3306
MYSQL_USER=replace-me
MYSQL_PASSWORD=replace-me
MYSQL_DATABASE=replace-me

WC_STORE_URL=https://shop.trufusionlabs.com
WC_CONSUMER_KEY=replace-me
WC_CONSUMER_SECRET=replace-me
WC_MAILER_URL=https://shop.trufusionlabs.com/wp-json/trufusion/v1/email/password-reset
WC_MAILER_SECRET=replace-with-the-same-value-as-TRUFUSION_MAILER_SECRET-in-wordpress
PASSWORD_RESET_PUBLIC_BASE_URL=https://www.trufusionlabs.com
PASSWORD_RESET_FALLBACK_EMAIL_ENABLED=true

# SMTP fallback for password resets and other backend-generated emails.
# Prefer the Woo mailer bridge above, but keep this configured so delivery does
# not silently depend on WordPress mail if the bridge fails.
MAIL_FROM="TrufusionLabs <support@trufusionlabs.com>"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USER=support@trufusionlabs.com
SMTP_PASS=replace-me

# Poll the support mailbox for delivery status notifications so bounced
# campaigns are revised from sent to failed automatically. Create a Gmail app
# password for support@trufusionlabs.com and store it only on the server as
# EMAIL_BOUNCE_IMAP_PASS. Once this poller is verified in production, disable
# any legacy Google Apps Script minute trigger that posts bounces to the webhook.
EMAIL_BOUNCE_POLL_ENABLED=true
EMAIL_BOUNCE_IMAP_HOST=imap.gmail.com
EMAIL_BOUNCE_IMAP_PORT=993
EMAIL_BOUNCE_IMAP_SSL=true
EMAIL_BOUNCE_IMAP_USER=support@trufusionlabs.com
EMAIL_BOUNCE_IMAP_PASS=replace-me
EMAIL_BOUNCE_IMAP_MAILBOX=INBOX
EMAIL_BOUNCE_POLL_INTERVAL_SECONDS=60
EMAIL_BOUNCE_IMAP_SEARCH_DAYS=14
EMAIL_BOUNCE_IMAP_MAX_MESSAGES=50
EMAIL_BOUNCE_IMAP_MARK_SEEN=false

STRIPE_MODE=live
STRIPE_SECRET_KEY=replace-me
STRIPE_WEBHOOK_SECRET=replace-me
VITE_STRIPE_PUBLISHABLE_KEY=replace-me

SHIPSTATION_API_KEY=replace-me
SHIPSTATION_API_SECRET=replace-me
SHIPSTATION_CARRIER_CODE=replace-me
SHIPSTATION_SERVICE_CODE=replace-me

# Optional runtime tuning
# LOG_LEVEL=info
# ORDER_TIMEZONE=America/Los_Angeles
# TRUFUSION_HEALTH_PASSWORD=replace-with-a-separate-health-password
# WOO_PRODUCT_DOC_SYNC_MODE=thread
# SHIPSTATION_STATUS_SYNC_MODE=thread
# UPS_STATUS_SYNC_MODE=thread
# PRESENCE_SWEEP_MODE=thread
# PATIENT_LINKS_SWEEP_MODE=thread

# Quote PDF rendering
# Leave QUOTE_PDF_ALLOW_TEXT_FALLBACK=false in production if you want export
# failures to be explicit instead of silently returning the crude text PDF.
# Set QUOTE_PDF_NODE_BINARY when the Python service cannot see node in PATH.
# On cPanel this is often /opt/cpanel/ea-nodejs20/bin/node or similar.
# Set PLAYWRIGHT_BROWSERS_PATH only if you rely on the Node/Playwright renderer.
# Set CHROMIUM_EXECUTABLE_PATH or PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH when a
# system Chrome/Chromium binary exists in a nonstandard location.
# QUOTE_PDF_ALLOW_TEXT_FALLBACK=false
# QUOTE_PDF_NODE_BINARY=/opt/cpanel/ea-nodejs20/bin/node
# PLAYWRIGHT_BROWSERS_PATH=/home/your-user/.cache/ms-playwright
# CHROMIUM_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/google-chrome-stable
